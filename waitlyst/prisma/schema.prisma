generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

// NextAuth required models
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id                      String         @id @default(cuid())
  name                    String?
  email                   String?        @unique
  emailVerified           DateTime?
  image                   String?
  stripeConnectId         String?
  stripeConnectOnboarded  Boolean        @default(false)
  accounts                Account[]
  sessions                Session[]
  createdLines            Line[]         @relation("LineCreator")
  positions               LinePosition[]
  createdAt               DateTime       @default(now())
}

model VerificationToken {
  id         String   @id @default(cuid())
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// Waitlyst app models
model Line {
  id              String         @id @default(cuid())
  name            String
  description     String?
  createdById     String
  createdBy       User           @relation("LineCreator", fields: [createdById], references: [id])
  positions       LinePosition[]
  isActive        Boolean        @default(true)
  isPublic        Boolean        @default(true)
  opensAt         DateTime?      // When the line opens for joining (null = open immediately)
  closesAt        DateTime?      // When the line stops accepting new joins (null = never closes)
  maxCapacity     Int?           // Maximum number of positions allowed (null = unlimited)
  ownerFeePercent Float          @default(0) // Percentage the line owner earns on each sale (e.g. 10 = 10%)
  announcement    String?        // Owner announcement shown as banner (max ~280 chars)
  announcementAt  DateTime?      // When the announcement was last set
  productName     String?        // Product name (e.g. "Nike Dunk Low Travis Scott")
  productImage    String?        // URL to product image
  productPrice    Float?         // Retail / MSRP price in dollars
  productUrl      String?        // Link to official product page
  allowResale     Boolean        @default(true)  // Whether position trading is enabled
  maxAskingPrice  Float?         // Maximum resale price cap (null = no limit)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([createdById])
}

model LinePosition {
  id          String    @id @default(cuid())
  lineId      String
  line        Line      @relation(fields: [lineId], references: [id], onDelete: Cascade)
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  position    Int       // 1 = first in line
  askingPrice Float?    // null = not for sale
  lockedUntil DateTime? // Position is locked for swap until this time
  lockedBy    String?   // Transaction ID that locked this position
  joinedAt    DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([lineId, userId])    // User can only be in a line once
  @@unique([lineId, position])  // Each position is unique per line
  @@index([lineId])
  @@index([userId])
}

model Transaction {
  id              String            @id @default(cuid())
  buyerId         String
  sellerId        String
  lineId          String
  amount          Float             // Seller's asking price (what seller receives)
  ownerFee        Float             @default(0) // Fee paid to line owner
  platformFee     Float             @default(0) // Fee paid to platform
  stripePaymentId String?
  status          TransactionStatus @default(PENDING)
  settledAt       DateTime?         // Set when both buyer and seller have left the line
  createdAt       DateTime          @default(now())

  @@index([lineId])
  @@index([buyerId])
  @@index([sellerId])
}

enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}
