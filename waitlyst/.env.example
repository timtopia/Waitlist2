# Database - Vercel Postgres (Neon)
# These are automatically set when you connect a Vercel Postgres database in the Vercel dashboard.
# For local dev, copy the values from Vercel Dashboard > Storage > your database > .env.local tab.
POSTGRES_PRISMA_URL="postgresql://username:password@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require&pgbouncer=true&connect_timeout=15"
POSTGRES_URL_NON_POOLING="postgresql://username:password@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require"

# Google OAuth - Get these from Google Cloud Console
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# NextAuth
AUTH_SECRET="generate-a-secret-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"
NEXTAUTH_URL="http://localhost:3000"

# Platform fee percentage on position sales (default: 5%)
PLATFORM_FEE_PERCENT="5"

# Resend - Email notifications (https://resend.com)
# When not set, email notifications are silently skipped (dev mode)
RESEND_API_KEY="re_..."

# Stripe - Get these from Stripe Dashboard
# When not set, the app runs in dev mode (position swaps happen without payment)
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
# To test webhooks locally, run: stripe listen --forward-to localhost:3000/api/webhooks/stripe
